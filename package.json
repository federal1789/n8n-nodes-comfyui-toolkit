{
  "name": "n8n-nodes-comfyui-toolkit",
  "version": "1.0.0",
  "description": "n8n custom nodes for ComfyUI — text-to-image, image-to-image, text-to-video, image-to-video",
  "keywords": [
    "n8n-community-node-package",
    "comfyui",
    "ai",
    "image-generation",
    "video-generation",
    "flux",
    "stable-diffusion"
  ],
  "author": {
    "name": "Ilker Umut",
    "url": "https://github.com/federal1789"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/federal1789/n8n-nodes-comfyui-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/federal1789/n8n-nodes-comfyui-toolkit/issues"
  },
  "homepage": "https://github.com/federal1789/n8n-nodes-comfyui-toolkit#readme",
  "main": "index.js",
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"nodes/**/*.svg\" dist/nodes/",
    "dev": "tsc --watch",
    "lint": "eslint nodes --ext .ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/ComfyUIUploadImage/ComfyUIUploadImage.node.js",
      "dist/nodes/ComfyUITextToImage/ComfyUITextToImage.node.js",
      "dist/nodes/ComfyUIImageToImage/ComfyUIImageToImage.node.js",
      "dist/nodes/ComfyUITextToVideo/ComfyUITextToVideo.node.js",
      "dist/nodes/ComfyUIImageToVideo/ComfyUIImageToVideo.node.js",
      "dist/nodes/ComfyUIGetResults/ComfyUIGetResults.node.js",
      "dist/nodes/ComfyUIWaitUntilResult/ComfyUIWaitUntilResult.node.js"
    ]
  },
  "dependencies": {
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "n8n-workflow": "*",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}